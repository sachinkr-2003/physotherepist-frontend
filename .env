# For web testing, use localhost
VITE_API_URL=http://localhost:5000

# VERY IMPORTANT FOR ANDROID APK:
# When you build the APK, you must change this to your computer's actual WiFi IP address
# Example: VITE_API_URL=http://192.168.1.5:5000
# Or if you deploy your backend to the internet (Render/Heroku), put the live URL here:
# Example: VITE_API_URL=https://vk-physio-backend.onrender.com
